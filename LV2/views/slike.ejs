<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Galerija Slika | Movie Archives</title>
    <link rel="stylesheet" href="/style.css"> 
    <style>
        body { font-family: sans-serif; background-color: #f4f4f4; margin: 0; }
        h1 { text-align: center; margin-top: 30px; color: #333; }

        /* Stilovi za galeriju */
        .gallery {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            justify-content: center;
            padding: 20px;
        }

        figure {
            margin: 0;
            width: 250px;
            border: 1px solid #ccc;
            padding: 10px;
            border-radius: 8px;
            background-color: #fff;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            text-align: center;
            transition: transform 0.2s;
        }

        figure:hover { transform: translateY(-5px); }

        figure img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-radius: 4px;
            display: block;
            cursor: pointer;
        }

        figcaption {
            margin-top: 10px;
            font-weight: bold;
            color: #555;
        }

        /* --- LIGHTBOX (Uvećani prikaz) --- */
        .lightbox-overlay {
            display: none; /* Sakriveno dok se ne klikne */
            position: fixed;
            z-index: 1000;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background-color: rgba(0, 0, 0, 0.9);
            justify-content: center;
            align-items: center;
            flex-direction: column;
        }

        /* Prikazuje overlay kada je ID u URL-u */
        .lightbox-overlay:target { display: flex; }

        .lightbox-overlay img {
            max-width: 90%;
            max-height: 80%;
            border: 3px solid white;
            box-shadow: 0 0 20px rgba(255,255,255,0.2);
        }

        .close-btn {
            position: absolute;
            top: 20px; right: 40px;
            color: white;
            font-size: 50px;
            text-decoration: none;
            font-weight: bold;
        }

        .back-btn {
            display: block;
            width: fit-content;
            margin: 20px auto;
            text-decoration: none;
            color: #e50914;
            font-weight: bold;
            padding: 10px 20px;
            border: 2px solid #e50914;
            border-radius: 5px;
        }
        .back-btn:hover { background-color: #e50914; color: white; }
    </style>
</head>
<body>

    <h1>Moja Dinamička Galerija</h1>
    
    <section class="gallery">
        <% images.forEach(image => { %>
            <figure>
                <a href="#open_<%= image.id %>">
                    <img src="<%= image.url %>" alt="<%= image.title %>">
                </a>
                <figcaption><%= image.title %></figcaption>
            </figure>

            <div id="open_<%= image.id %>" class="lightbox-overlay">
                <a href="#!" class="close-btn">&times;</a>
                <img src="<%= image.url %>" alt="<%= image.title %>">
                <p style="color: white; margin-top: 15px; font-size: 1.2em;">
                    <%= image.title %>
                </p>
            </div>
        <% }); %>
    </section>

    <a href="/" class="back-btn">← Povratak na početnu</a>

</body>
</html>